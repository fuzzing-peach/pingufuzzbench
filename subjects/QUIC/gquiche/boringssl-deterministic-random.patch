 #include <stdio.h>
@@ -134,6 +135,51 @@ static void maybe_set_extra_getrandom_flags(void) {
 
 static CRYPTO_once_t rand_once = CRYPTO_ONCE_INIT;
 
+static int use_deterministic_random() {
+  const char *env = getenv("FAKE_RANDOM");
+  return env != nullptr && env[0] != '\0' && env[0] != '0';
+}
+
+static uint64_t deterministic_seed_from_env() {
+  const char *seed_str = getenv("FAKERANDOM_SEED");
+  if (seed_str == nullptr || seed_str[0] == '\0') {
+    return UINT64_C(0x243B50D243B50D);
+  }
+  char *end = nullptr;
+  errno = 0;
+  unsigned long long parsed = strtoull(seed_str, &end, 0);
+  if (errno != 0 || end == seed_str) {
+    return UINT64_C(0x243B50D243B50D);
+  }
+  return static_cast<uint64_t>(parsed);
+}
+
+static uint64_t deterministic_splitmix64(uint64_t *state) {
+  uint64_t z = (*state += UINT64_C(0x9E3779B97F4A7C15));
+  z = (z ^ (z >> 30)) * UINT64_C(0xBF58476D1CE4E5B9);
+  z = (z ^ (z >> 27)) * UINT64_C(0x94D049BB133111EB);
+  return z ^ (z >> 31);
+}
+
+static void deterministic_fill(uint8_t *out, size_t len) {
+  static thread_local int initialized = 0;
+  static thread_local uint64_t state = 0;
+  if (!initialized) {
+    state = deterministic_seed_from_env();
+    initialized = 1;
+  }
+  while (len >= sizeof(uint64_t)) {
+    uint64_t v = deterministic_splitmix64(&state);
+    OPENSSL_memcpy(out, &v, sizeof(v));
+    out += sizeof(v);
+    len -= sizeof(v);
+  }
+  if (len > 0) {
+    uint64_t v = deterministic_splitmix64(&state);
+    OPENSSL_memcpy(out, &v, len);
+  }
+}
